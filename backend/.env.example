# Optional — enables real Google competition scores (default: heuristic)
ENABLE_SEARCH_SCORING=1
SERPER_API_KEY=

# Optional — checks site:usenaive.ai per query (default: all rows show "none")
ENABLE_NAIVE_CHECK=1

# Alternative to Serper:
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=

# Deployed frontend (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
